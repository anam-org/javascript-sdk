{
  "compilerOptions": {
    "target": "es2015",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "declaration": true,
    "declarationMap": true,
    "module": "commonjs",
    "outDir": "dist/main",
    "rootDir": "src",
    "sourceMap": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "stripInternal": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": ["src"],
  "exclude": ["node_modules/**/*.ts"]
}
